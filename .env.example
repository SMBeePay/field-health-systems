# Environment Variables — copy to .env.local for local dev
# For production, set these in Vercel → Settings → Environment Variables

# Database (Neon Postgres — get from Vercel → Storage → your Neon DB → .env tab)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Admin Account (REQUIRED)
ADMIN_EMAIL="admin@fieldhealthsystems.com"
ADMIN_PASSWORD="your-secure-admin-password"

# Demo Account (REQUIRED)
DEMO_EMAIL="demo@fieldhealthsystems.com"
DEMO_PASSWORD="your-secure-demo-password"

# NextAuth (REQUIRED)
NEXTAUTH_URL="https://www.fieldhealthsystems.com"
NEXTAUTH_SECRET="run: openssl rand -base64 32"

# Email (Optional)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="your-email@example.com"
SMTP_PASSWORD="your-smtp-password"
SMTP_FROM="noreply@fieldhealthsystems.com"
